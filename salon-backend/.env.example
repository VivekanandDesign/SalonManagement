# ── Database ──
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/glowdesk?schema=public"

# ── JWT ──
JWT_SECRET="generate-a-strong-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# ── Server ──
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# ── OAuth (Google) ──
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ── OAuth (Facebook) ──
FACEBOOK_APP_ID="your-facebook-app-id"

# ── Seed passwords (used by prisma/seed.js) ──
SEED_ADMIN_PASSWORD="admin123"
SEED_STYLIST_PASSWORD="stylist123"
SEED_RECEPTIONIST_PASSWORD="recep123"
